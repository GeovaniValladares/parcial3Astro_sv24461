---
import AuthLayout from "../layouts/AuthLayout.astro";
---

<AuthLayout title="register">
  <div class="flex justify-center self-center z-10">
    <div class="p-12 bg-white mx-auto rounded-2xl w-100">
      <div class="mb-4">
        <h3 class="font-semibold text-2xl text-gray-800">Registro</h3>
        <p class="text-gray-500">Crea tu cuenta</p>
      </div>

      <form id="register-form" class="space-y-5">
        <div>
          <label class="text-sm font-medium text-gray-700">Nombre</label>
          <input type="text" name="name" required class="w-full border p-2 rounded lg"/>
        </div>

        <div>
          <label class="text-sm font-medium text-gray-700">Email</label>
          <input type="email" name="email" required class="w-full border p-2 rounded lg"/>
        </div>

        <div>
          <label class="text-sm font-medium text-gray-700">Password</label>
          <input type="password" name="password" required class="w-full border p-2 rounded lg"/>
        </div>

        <div>
          <label class="text-sm font-medium text-gray-700">Rol</label>
          <select name="role" required class="w-full border p-2 rounded lg">
            <option value="user">User</option>
            <option value="admin">Admin</option>
          </select>
        </div>

        <div class="flex justify-between">
          <a href="/login" class="text-green-400">
            ¿Ya tienes cuenta?
          </a>
        </div>

        <button id="btn-submit" type="submit"
          class="w-full bg-green-400 text-white p-3 rounded-full cursor-pointer disabled:bg-gray-400">
          Registrarse
        </button>
      </form>
    </div>
  </div>
</AuthLayout>

<script>
  import { actions } from "astro:actions";
  import Swal from "sweetalert2";

  const form = document.querySelector("#register-form") as HTMLFormElement;
  const btnSubmit = document.querySelector("#btn-submit") as HTMLButtonElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    btnSubmit.disabled = true;

    const formData = new FormData(form);
    const name = formData.get("name") as string;
    const email = formData.get("email") as string;
    const password = formData.get("password") as string;
    const role = formData.get("role") as string;

    const { error } = await actions.auth.registerUser({ name, email, password, role });

    if (error) {
      Swal.fire({
        icon: "error",
        title: "Error",
        text: error.message
      });
      btnSubmit.disabled = false;
      return;
    }

    await Swal.fire({
      icon: "success",
      title: "Registro exitoso",
      text: "¡Bienvenido!",
      timer: 1500,
      showConfirmButton: false
    });

    window.location.replace("/protected");
  });
</script>