---
import MainLayout from "../../layouts/MainLayout.astro";
import { db, User, count, desc, like, and, eq, sql } from "astro:db";

const { user: currentUser } = Astro.locals;

if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect("/protected");
}

// Parámetros de búsqueda y filtros
const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get("page") || "1");
const search = url.searchParams.get("search") || "";
const roleFilter = url.searchParams.get("role") || "";
const limit = 5;
const offset = (page - 1) * limit;

// Estadísticas
const [totalUsersRes] = await db.select({ value: count() }).from(User);
const [adminsRes] = await db.select({ value: count() }).from(User).where(eq(User.role, 'admin'));
const totalUsers = totalUsersRes.value;
const adminCount = adminsRes.value;

// Filtros para la consulta
const filters = [];
if (search) filters.push(like(User.name, `%${search}%`));
if (roleFilter) filters.push(eq(User.role, roleFilter));

const whereClause = filters.length > 0 ? and(...filters) : undefined;

// Obtener usuarios paginados y filtrados
const users = await db.select().from(User)
  .where(whereClause)
  .orderBy(desc(User.createdAt))
  .limit(limit)
  .offset(offset);

// Total filtrado para la paginación
const [filteredCountRes] = await db.select({ value: count() }).from(User).where(whereClause);
const totalPages = Math.ceil(filteredCountRes.value / limit);
---

<MainLayout title="Panel de Administración" maxWidth="max-w-6xl">
  <div class="py-6 space-y-8">
    
    {/* Tarjetas de Estadísticas */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-gray-50 p-6 rounded-xl border border-gray-100 shadow-sm">
        <p class="text-sm text-gray-500 font-medium">Total usuarios</p>
        <p class="text-3xl font-bold text-gray-800">{totalUsers}</p>
      </div>
      <div class="bg-gray-50 p-6 rounded-xl border border-gray-100 shadow-sm">
        <p class="text-sm text-gray-500 font-medium">Admins</p>
        <p class="text-3xl font-bold text-gray-800">{adminCount}</p>
      </div>
      <div class="bg-gray-50 p-6 rounded-xl border border-gray-100 shadow-sm">
        <p class="text-sm text-gray-500 font-medium">Página actual</p>
        <p class="text-3xl font-bold text-gray-800">{page} / {totalPages || 1}</p>
      </div>
    </div>

    {/* Controles de Búsqueda y Acciones */}
    <div class="flex flex-col md:flex-row gap-4 items-center justify-between bg-white p-4 rounded-xl shadow-sm border border-gray-100">
      <form id="search-form" class="flex flex-col md:flex-row gap-3 w-full md:w-auto">
        <input 
          type="text" 
          name="search" 
          placeholder="Buscar por nombre..." 
          value={search}
          class="px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none w-full md:w-64"
        />
        <select 
          name="role" 
          class="px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none"
        >
          <option value="">Todos los roles</option>
          <option value="user" selected={roleFilter === 'user'}>User</option>
          <option value="admin" selected={roleFilter === 'admin'}>Admin</option>
        </select>
        <button type="submit" class="bg-gray-800 text-white px-4 py-2 rounded-lg hover:bg-gray-700 transition font-bold">
          Filtrar
        </button>
      </form>

      <div class="flex gap-2 w-full md:w-auto justify-end">
        <button onclick="window.print()" class="flex items-center gap-2 px-4 py-2 border rounded-lg hover:bg-gray-50 font-bold transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
          </svg>
          Imprimir
        </button>
        <button id="btn-export" class="flex items-center gap-2 px-4 py-2 border rounded-lg hover:bg-gray-50 font-bold transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          PDF
        </button>
        <button id="btn-add-user" class="bg-green-500 text-white px-4 py-2 rounded-lg hover:bg-green-600 font-bold transition shadow-sm">
          + Agregar usuario
        </button>
      </div>
    </div>

    {/* Tabla de Usuarios */}
    <div class="bg-white shadow-sm rounded-xl border border-gray-100 overflow-hidden">
      <table id="users-table" class="min-w-full leading-normal">
        <thead>
          <tr class="bg-gray-50 text-left text-gray-500 font-bold text-xs uppercase tracking-wider">
            <th class="px-5 py-4 border-b">Nombre</th>
            <th class="px-5 py-4 border-b">Email</th>
            <th class="px-5 py-4 border-b text-center">Rol</th>
            <th class="px-5 py-4 border-b">Creado</th>
            <th class="px-5 py-4 border-b text-center">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {users.map((user) => (
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition">
              <td class="px-5 py-4 text-sm font-medium text-gray-700">{user.name}</td>
              <td class="px-5 py-4 text-sm text-gray-600">{user.email}</td>
              <td class="px-5 py-4 text-sm text-center">
                <span class={`px-3 py-1 rounded-full text-[10px] font-bold uppercase ${user.role === 'admin' ? 'bg-red-100 text-red-600' : 'bg-blue-100 text-blue-600'}`}>
                  {user.role}
                </span>
              </td>
              <td class="px-5 py-4 text-sm text-gray-500">
                {user.createdAt.toLocaleDateString()}
              </td>
              <td class="px-5 py-4 text-sm text-center space-x-3">
                <button 
                  class="btn-edit text-blue-600 hover:text-blue-800 font-bold"
                  data-user={JSON.stringify(user)}
                >
                  Editar
                </button>
                {currentUser.id !== user.id && (
                  <button 
                    class="btn-delete text-red-600 hover:text-red-800 font-bold"
                    data-id={user.id}
                  >
                    Eliminar
                  </button>
                )}
              </td>
            </tr>
          ))}
          {users.length === 0 && (
            <tr>
              <td colspan="5" class="px-5 py-10 text-center text-gray-500 italic">
                No se encontraron usuarios con los filtros seleccionados.
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>

    {/* Paginación */}
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-600">
      <p>
        Mostrando <span class="font-bold">{users.length}</span> de <span class="font-bold">{filteredCountRes.value}</span> usuarios
      </p>
      
      <div class="flex items-center gap-1">
        <a 
          href={`?page=${Math.max(1, page - 1)}&search=${search}&role=${roleFilter}`} 
          class={`p-2 border rounded-lg hover:bg-gray-50 ${page === 1 ? 'pointer-events-none opacity-50' : ''}`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </a>
        
        {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
          <a 
            href={`?page=${p}&search=${search}&role=${roleFilter}`} 
            class={`w-10 h-10 flex items-center justify-center border rounded-lg font-bold transition ${p === page ? 'bg-green-500 text-white border-green-500' : 'hover:bg-gray-50'}`}
          >
            {p}
          </a>
        ))}

        <a 
          href={`?page=${Math.min(totalPages, page + 1)}&search=${search}&role=${roleFilter}`} 
          class={`p-2 border rounded-lg hover:bg-gray-50 ${page === totalPages || totalPages === 0 ? 'pointer-events-none opacity-50' : ''}`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { actions } from "astro:actions";
  import Swal from "sweetalert2";

  // Manejo de exportación a PDF (Simulado con impresión)
  document.querySelector("#btn-export")?.addEventListener("click", () => {
    window.print();
  });

  // Botón Agregar Usuario
  document.querySelector("#btn-add-user")?.addEventListener("click", async () => {
    const { value: formValues } = await Swal.fire({
      title: 'Agregar Nuevo Usuario',
      html:
        '<input id="swal-name" class="swal2-input" placeholder="Nombre">' +
        '<input id="swal-email" type="email" class="swal2-input" placeholder="Email">' +
        '<input id="swal-password" type="password" class="swal2-input" placeholder="Contraseña">' +
        '<select id="swal-role" class="swal2-input">' +
          '<option value="user">User</option>' +
          '<option value="admin">Admin</option>' +
        '</select>',
      focusConfirm: false,
      showCancelButton: true,
      confirmButtonText: 'Guardar',
      cancelButtonText: 'Cancelar',
      preConfirm: () => {
        const name = (document.getElementById('swal-name') as HTMLInputElement).value;
        const email = (document.getElementById('swal-email') as HTMLInputElement).value;
        const password = (document.getElementById('swal-password') as HTMLInputElement).value;
        const role = (document.getElementById('swal-role') as HTMLSelectElement).value;
        
        if (!name || !email || !password) {
          Swal.showValidationMessage('Todos los campos son obligatorios');
          return false;
        }
        return { name, email, password, role };
      }
    });

    if (formValues) {
      const { error } = await actions.admin.createUser(formValues);
      if (error) {
        Swal.fire('Error', error.message, 'error');
      } else {
        Swal.fire('¡Éxito!', 'Usuario creado correctamente', 'success').then(() => {
          window.location.reload();
        });
      }
    }
  });

  // Botones Editar
  document.querySelectorAll(".btn-edit").forEach(button => {
    button.addEventListener("click", async (e) => {
      const userData = JSON.parse((e.currentTarget as HTMLButtonElement).dataset.user!);
      
      const { value: formValues } = await Swal.fire({
        title: 'Editar Usuario',
        html:
          `<input id="swal-name" class="swal2-input" placeholder="Nombre" value="${userData.name}">` +
          `<input id="swal-email" type="email" class="swal2-input" placeholder="Email" value="${userData.email}">` +
          '<select id="swal-role" class="swal2-input">' +
            `<option value="user" ${userData.role === 'user' ? 'selected' : ''}>User</option>` +
            `<option value="admin" ${userData.role === 'admin' ? 'selected' : ''}>Admin</option>` +
          '</select>',
        focusConfirm: false,
        showCancelButton: true,
        confirmButtonText: 'Actualizar',
        cancelButtonText: 'Cancelar',
        preConfirm: () => {
          const name = (document.getElementById('swal-name') as HTMLInputElement).value;
          const email = (document.getElementById('swal-email') as HTMLInputElement).value;
          const role = (document.getElementById('swal-role') as HTMLSelectElement).value;
          
          if (!name || !email) {
            Swal.showValidationMessage('Nombre y email son obligatorios');
            return false;
          }
          return { id: userData.id, name, email, role };
        }
      });

      if (formValues) {
        const { error } = await actions.admin.updateUser(formValues);
        if (error) {
          Swal.fire('Error', error.message, 'error');
        } else {
          Swal.fire('¡Éxito!', 'Usuario actualizado correctamente', 'success').then(() => {
            window.location.reload();
          });
        }
      }
    });
  });

  // Botones Eliminar
  document.querySelectorAll(".btn-delete").forEach(button => {
    button.addEventListener("click", async (e) => {
      const userId = (e.currentTarget as HTMLButtonElement).dataset.id!;
      
      const result = await Swal.fire({
        title: '¿Estás seguro?',
        text: "Esta acción no se puede deshacer",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'Sí, eliminar',
        cancelButtonText: 'Cancelar'
      });

      if (result.isConfirmed) {
        const { error } = await actions.admin.deleteUser({ id: userId });
        if (error) {
          Swal.fire('Error', error.message, 'error');
        } else {
          Swal.fire('Eliminado', 'El usuario ha sido eliminado', 'success').then(() => {
            window.location.reload();
          });
        }
      }
    });
  });
</script>

<style>
  @media print {
    .bg-white, .bg-gray-50 {
      background-color: transparent !important;
      box-shadow: none !important;
      border: none !important;
    }
    .btn-edit, .btn-delete, #btn-add-user, #search-form, #btn-export, .grid, .flex.flex-col.md\:flex-row.justify-between, nav {
      display: none !important;
    }
    table {
      width: 100% !important;
      border-collapse: collapse !important;
    }
    th, td {
      border: 1px solid #e2e8f0 !important;
      padding: 12px !important;
    }
    body {
      padding: 0 !important;
    }
  }
</style>