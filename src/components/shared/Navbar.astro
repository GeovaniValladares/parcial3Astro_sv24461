---
const { user } = Astro.locals;
const isLoggedIn = !!user;
---

<nav class="flex justify-between px-10 py-5 items-center bg-white shadow-sm">
  <h1 class="text-xl font-bold text-green-600">Astro Auth</h1>

  <ul class="flex items-center space-x-6 font-medium text-gray-700">
    <li><a href="/" class="hover:text-green-500">Inicio</a></li>
    <li><a href="/intro" class="hover:text-green-500">Docs</a></li>

    {
      isLoggedIn && (
        <>
          {user?.role === 'admin' && (
            <li><a href="/admin" class="hover:text-green-500">Admin</a></li>
          )}
          <li><a href="/protected" class="hover:text-green-500">Protegido</a></li>
        </>
      )
    }

    {
      !isLoggedIn ? (
        <li><a href="/login" class="bg-green-500 text-white px-4 py-2 rounded-lg hover:bg-green-600">Ingresar</a></li>
      ) : (
        <li class="flex items-center space-x-4 border-l pl-4">
          <div class="flex flex-col text-right">
            <span class="text-sm font-bold text-gray-900">{user.name}</span>
            <span class="text-xs text-gray-500">{user.email} ({user.role})</span>
          </div>
          <button id="nav-logout" class="text-red-500 hover:text-red-700 cursor-pointer font-bold">
            Salir
          </button>
        </li>
      )
    }
  </ul>
</nav>

<script>
  import { actions } from "astro:actions";

  const logoutBtn = document.querySelector("#nav-logout");

  logoutBtn?.addEventListener("click", async () => {
    await actions.auth.logoutUser();
    window.location.replace("/login");
  });
</script>